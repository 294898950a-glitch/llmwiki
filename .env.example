# Notion integration credentials
# 在 https://www.notion.so/my-integrations 创建 integration 后得到
NOTION_API_KEY=YOUR_NOTION_INTEGRATION_TOKEN

# Raw Inbox 数据库 ID
# 打开数据库 → 右上角 ... → Copy link，URL 里 workspace/ 后面那串就是 ID
NOTION_RAW_INBOX_DB_ID=YOUR_RAW_INBOX_DATABASE_ID

# Wiki 数据库 ID
NOTION_WIKI_DB_ID=YOUR_WIKI_DATABASE_ID

# DeepSeek API key（llm-refine / llm-validate / pipeline 子命令需要；其他命令不依赖 LLM）
# 二选一：inline key 或指向 key 文件的路径
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_API_KEY_FILE=/path/to/DEEPSEEK_API_KEY.txt

# Kimi (Moonshot) API key（llm-refine-page / pipeline 默认 primary generator 用）
# KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KIMI_API_KEY_FILE=/path/to/KIMI_API_KEY.txt

# Gemini API key（pipeline 的仲裁员 Gemini 2.5 Flash 用；单独跑 llm-refine / llm-validate 可选）
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY_FILE=/path/to/GEMINI_API_KEY.txt
